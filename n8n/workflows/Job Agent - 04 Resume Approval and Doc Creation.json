        "url": "=https://testashok1.openai.azure.com/openai/deployments/Test-Ashok-1-gpt-4o/chat/completions?api-version=2024-02-01",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an expert resume writer. Revise the resume based on the reviewer's feedback. Return JSON with: resume_html, resume_markdown, tailoring_rationale. Do NOT fabricate experience.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"CURRENT RESUME:\\n{{$json.resume_markdown}}\\n\\nREVIEW NOTES:\\n{{$json.review_notes}}\\n\\nJOB TITLE: {{$json.title}}\\nCOMPANY: {{$json.company_name}}\"\n    }\n  ],\n  \"response_format\": { \"type\": \"json_object\" },\n  \"max_tokens\": 3000\n}",
        "options": {}
      },
      "id": "d178d64d-4a6a-42f4-a7af-c24f15f60ef0",
      "name": "Azure OpenAI Revise Resume",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        0,
        0
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "jjUOHftcBqLwwjjm",
          "name": "Azure OpenAI API Key-03May26"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const job = $('Has Review Notes?').item.json;\nconst raw = $json.choices?.[0]?.message?.content || '{}';\nlet revised;\ntry { revised = JSON.parse(raw); } catch (e) { revised = {}; }\nreturn [{ json: {\n  ...job,\n  resume_markdown: revised.resume_markdown || job.resume_markdown,\n  resume_html: revised.resume_html || job.resume_html\n} }];"
      },
      "id": "141388f4-f230-4912-8e1d-91f1f2339276",
