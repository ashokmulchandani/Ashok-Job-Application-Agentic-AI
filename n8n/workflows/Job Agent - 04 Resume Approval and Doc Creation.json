          "id": "SMbQovwtw9fzGPf2",
          "name": "Google Drive account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const result = $json;\nconst job = $('Prepare HTML Binary').item.json;\nconst docUrl = result.webViewLink || (result.id ? 'https://drive.google.com/file/d/' + result.id + '/view' : '');\n\nreturn [{ json: {\n  job_id: job.job_id,\n  job_url_hash: job.job_url_hash,\n  doc_url: docUrl,\n  status: 'resume_generated',\n  updated_at: new Date().toISOString()\n} }];\n"
      },
