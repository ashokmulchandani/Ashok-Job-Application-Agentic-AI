    {
      "parameters": {
        "jsCode": "const job = $json;\nconst resume = (job.resume_markdown || '').replace(/[\\n\\r\\t]/g, ' ');\nconst master = (job.master_resume || '').replace(/[\\n\\r\\t]/g, ' ');\nconst notes = (job.review_notes || '').replace(/[\\n\\r\\t]/g, ' ');\n\nconst body = {\n  messages: [\n    {\n      role: \"system\",\n      content: \"You are an expert resume writer. Revise the resume based on reviewer feedback and master resume data. Return JSON with: resume_html, resume_markdown, tailoring_rationale. HTML: font-family Google Sans Text, Arial, sans-serif; body 10pt; headers 13pt bold; color #1B1C1D; line-height 114%; 1px solid #1B1C1D separator under name; disc bullet markers. Do NOT fabricate experience.\"\n    },\n    {\n      role: \"user\",\n      content: \"CURRENT RESUME: \" + resume + \" MASTER RESUME: \" + master + \" REVIEW NOTES: \" + notes + \" JOB TITLE: \" + job.title + \" COMPANY: \" + job.company_name\n    }\n  ],\n  response_format: { type: \"json_object\" },\n  max_tokens: 4500\n};\n\nreturn [{ json: { ...job, body_string: JSON.stringify(body) } }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1680,
        400
      ],
      "id": "f9787af7-dc08-4174-9f3c-8f269ddc64ec",
      "name": "Prepare Revision Request"
    },
    {
      "parameters": {
        "jsCode": "const job = $json;\n\n// Build filename\nconst now = new Date();\nconst day = String(now.getDate()).padStart(2, '0');\nconst months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];\nconst mon = months[now.getMonth()];\nconst yr = String(now.getFullYear()).slice(-2);\nconst dateStr = day + '_' + mon + '_' + yr;\nconst kw = (job.search_keywords || job.title || '').replace(/[^a-zA-Z0-9]/g, '_');\nconst company = (job.company_name || '').replace(/[^a-zA-Z0-9]/g, '_');\nconst title = (job.title || '').replace(/[^a-zA-Z0-9]/g, '_');\nconst loc = (job.location || 'Sydney').replace(/[^a-zA-Z0-9]/g, '_');\nconst baseName = 'Ashok_Mulchandani_' + kw + '_' + dateStr + '_resume_' + company + '_' + title + '_' + loc;\n\n// Get resume HTML\nlet html = job.resume_html || '';\nif (!html && job.resume_markdown) {\n  html = '<html><body><pre>' + job.resume_markdown + '</pre></body></html>';\n}\nif (!html) html = '<html><body>No resume content</body></html>';\n\nreturn [{ json: { ...job, file_name: baseName, resume_html_content: html } }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1040,
        656
      ],
      "id": "efe92583-6356-4a77-85f9-9a7783638a2c",
      "name": "Prepare Doc Data"
    },
    {
      "parameters": {
        "jsCode": "const items = $('Read Approved Jobs').all();\nconst approved = items.filter(i => (i.json.status || '').trim().toLowerCase() === 'approved');\nif (approved.length === 0) throw new Error('No approved jobs found');\nreturn approved.map(i => ({ json: i.json }));\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2320,
        560
      ],
      "id": "8c484c72-09aa-4894-9f13-c0dec6f448a9",
      "name": "Filter Approved Only"
    },
    {
      "parameters": {
        "jsCode": "const job = $json;\nconst html = job.resume_html_content || '<html><body>No content</body></html>';\nconst fileName = job.file_name + '.html';\n\n// Convert HTML string to base64 for binary\nconst base64 = Buffer.from(html, 'utf-8').toString('base64');\n\nreturn [{\n  json: { ...job, html_file_name: fileName, doc_file_name: job.file_name },\n  binary: {\n    data: {\n      data: base64,\n      mimeType: 'text/html',\n      fileName: fileName\n    }\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -864,
        656
      ],
      "id": "fdd79f42-dfbd-4ab5-973f-38e1e3706156",
      "name": "Prepare HTML Binary"
    },
