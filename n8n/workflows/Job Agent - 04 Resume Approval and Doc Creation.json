        "jsCode": "const job = $('Has Review Notes?').item.json || $('Parse Revised Resume').item.json;\nreturn [{ json: {\n  job_id: job.job_id,\n  job_url_hash: job.job_url_hash,\n  status: 'resume_generated',\n  resume_doc_url: $json.documentUrl || $json.url || '',\n  updated_at: new Date().toISOString()\n} }];"
