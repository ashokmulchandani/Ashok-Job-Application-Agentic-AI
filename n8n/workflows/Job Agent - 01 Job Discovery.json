{
  "name": "Job Agent - 01 Job Discovery",
  "nodes": [
    {
      "parameters": {},
      "id": "13666a01-c245-4d21-887c-60b1ea1571ab",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        -1920,
        160
      ]
    },
    {
      "parameters": {
        "jsCode": "// If a specific keyword is passed via manual trigger input, use only that\n// Otherwise run all 16 default searches\nconst allSearches = [\n  { keywords: 'AI-Engineer', location: 'Sydney-NSW', site: 'seek' },\n  { keywords: 'AI-ML-Engineer', location: 'Sydney-NSW', site: 'seek' },\n  { keywords: 'Continuous-Improvement-Specialist', location: 'Sydney-NSW', site: 'seek' },\n  { keywords: 'Continuous-Improvement-Manager', location: 'Sydney-NSW', site: 'seek' },\n  { keywords: 'Process-Improvement-Analyst', location: 'Sydney-NSW', site: 'seek' },\n  { keywords: 'Operations-Improvement-Manager', location: 'Sydney-NSW', site: 'seek' },\n  { keywords: 'Operations-Improvement-Analyst', location: 'Sydney-NSW', site: 'seek' },\n  { keywords: 'Agentic-AI-Automation-Engineer', location: 'Sydney-NSW', site: 'seek' },\n  { keywords: 'ISO-9001-Quality-Manager', location: 'Sydney-NSW', site: 'seek' },\n  { keywords: 'Quality-Assurance-Manager', location: 'Sydney-NSW', site: 'seek' },\n  { keywords: 'Quality-Manager', location: 'Sydney-NSW', site: 'seek' },\n  { keywords: 'Lean-Six-Sigma', location: 'Sydney-NSW', site: 'seek' },\n  { keywords: 'AI-Adoption-Specialist', location: 'Sydney-NSW', site: 'seek' },\n  { keywords: 'AI-Adoption-Manager', location: 'Sydney-NSW', site: 'seek' },\n  { keywords: 'Change-Manager', location: 'Sydney-NSW', site: 'seek' },\n  { keywords: 'Process-Automation-Engineer', location: 'All-Australia', site: 'seek' }\n];\n\n// Check if manual input provides a keyword override\nconst input = $input.first()?.json || {};\nlet searches = allSearches;\n\nif (input.keyword) {\n  const kw = input.keyword.trim().replace(/\\s+/g, '-');\n  const loc = (input.location || 'Sydney-NSW').trim().replace(/\\s+/g, '-');\n  searches = [{ keywords: kw, location: loc, site: 'seek' }];\n}\n\nconst urls = searches.map(s => {\n  if (s.site === 'seek') {\n    return { json: { search_url: `https://au.seek.com/${s.keywords}-jobs/in-${s.location}`, keywords: s.keywords.replace(/-/g, ' '), location: s.location.replace(/-/g, ' '), site: s.site } };\n  }\n  return { json: { search_url: '', keywords: s.keywords, location: s.location, site: s.site } };\n});\nreturn urls;"
      },
      "id": "3a013c41-784c-4f62-8cfa-965d3bb92513",
      "name": "Build Search URLs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1680,
        160
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.firecrawl.dev/v1/scrape",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"url\": \"{{$json.search_url}}\",\n  \"formats\": [\"markdown\"],\n  \"onlyMainContent\": true\n}",
        "options": {
          "timeout": 30000,
          "batching": {
            "batch": {
              "batchSize": 2,
              "batchInterval": 5000
            }
          }
        }
      },
      "id": "7e7c2bcc-56b9-47de-9f98-f67543eed903",
      "name": "Firecrawl Scrape Search Page",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -1440,
        160
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "rBgY4HYcYC151dgK",
          "name": "Firecrawl API Key-Latest-03May26"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const markdown = $json.data?.markdown || '';\nconst searchMeta = $('Build Search URLs').item.json;\n\nfunction hashText(input) {\n  let h1 = 0xdeadbeef;\n  let h2 = 0x41c6ce57;\n  for (let i = 0; i < input.length; i++) {\n    const ch = input.charCodeAt(i);\n    h1 = Math.imul(h1 ^ ch, 2654435761);\n    h2 = Math.imul(h2 ^ ch, 1597334677);\n  }\n  h1 = Math.imul(h1 ^ (h1 >>> 16), 2246822507) ^ Math.imul(h2 ^ (h2 >>> 13), 3266489909);\n  h2 = Math.imul(h2 ^ (h2 >>> 16), 2246822507) ^ Math.imul(h1 ^ (h1 >>> 13), 3266489909);\n  return ((h2 >>> 0).toString(16).padStart(8, '0') + (h1 >>> 0).toString(16).padStart(8, '0'));\n}\n\nconst jobRegex = /###\\s*\\[([^\\]]+)\\]\\((https:\\/\\/au\\.seek\\.com\\/job\\/\\d+[^)]*?)\\)[\\s\\S]*?at\\[([^\\]]+)\\]\\((https?:\\/\\/[^)]+)\\)/g;\nconst jobs = [];\nconst seen = new Set();\nlet match;\nlet serialNo = 0;\n\n\nwhile ((match = jobRegex.exec(markdown)) !== null) {\n  const title = match[1].trim();\n  const jobUrl = match[2].split('?')[0].trim();\n  const company = match[3].trim();\n  const companyUrl = match[4] ? match[4].split(' ')[0].trim() : '';\n\n\n  const dedupKey = `${company}|${title}`.toLowerCase().replace(/[^a-z0-9|]/g, '');\n  const hash = hashText(dedupKey);\n\n  if (seen.has(hash)) continue;\n  seen.add(hash);\n\n  const afterMatch = markdown.substring(match.index + match[0].length, match.index + match[0].length + 800);\n\n  const locMatch = afterMatch.match(/\\[([^\\]]*(?:Sydney|NSW|Melbourne|Brisbane|Australia|Remote)[^\\]]*)\\]/i);\n  const location = locMatch ? locMatch[1].replace(/\\s*\"[^\"]*\"/g, '').trim() : searchMeta.location;\n\n  const salaryMatch = afterMatch.match(/(\\$[\\d,]+(?:\\s*[–\\-]\\s*\\$[\\d,]+)?(?:\\s*(?:per|p\\.?a|k|K|per year|per annum|per hour))?[^\\n]*)/i);\n  const salary = salaryMatch ? salaryMatch[1].trim() : '';\n\n  const remoteMatch = afterMatch.match(/\\((Hybrid|Remote|On-?site)\\)/i);\n  const remotePolicy = remoteMatch ? remoteMatch[1].toLowerCase() : 'unknown';\n\n  const contractMatch = afterMatch.match(/This is a (Full time|Contract\\/Temp|Part time|Casual) job/i);\n  const contractType = contractMatch ? contractMatch[1].toLowerCase() : '';\n\n  const descLines = afterMatch.split('\\n').filter(l => {\n    const t = l.trim();\n    return t && t.length > 10 && !t.includes('subClassification') && !t.includes('classification:') && !t.match(/^\\d+[dh] ago/) && !t.includes('Limit results') && !t.includes('Jobs at') && !t.startsWith('at[') && !t.startsWith('Recruited by') && !t.startsWith('![');\n  });\n  const description = descLines.slice(0, 3).map(l => l.replace(/^-\\s*/, '').trim()).filter(Boolean).join(' | ');\n\n  serialNo++;\njobs.push({\n    json: {\n      serial_no: serialNo,\n      job_id: `job_${hash.slice(0, 12)}`,\n      job_url_hash: hash,\n      job_url: jobUrl,\n      title,\n      company_name: company,\n      company_url: companyUrl,\n      company_website: '',\n      location,\n      remote_policy: remotePolicy,\n      salary,\n      contract_type: contractType,\n      posted_at: '',\n      apply_url: jobUrl,\n      description,\n      source: `seek_${searchMeta.keywords}`,\n      search_keywords: searchMeta.keywords,\n      status: 'discovered',\n      fit_score: '',\n      fit_decision: '',\n      fit_rationale: '',\n      matched_requirements: '',\n      missing_requirements: '',\n      company_summary: '',\n      resume_doc_url: '',\n      job_pdf_url: '',\n      review_notes: '',\n      applied_at: '',\n      created_at: new Date().toISOString(),\n      updated_at: new Date().toISOString(),\n      error: ''\n    }\n  });\n}\n\nif (jobs.length === 0) {\n  return [{ json: { _empty: true, search_url: searchMeta.search_url, message: 'No jobs extracted from markdown' } }];\n}\nreturn jobs;\n"
      },
