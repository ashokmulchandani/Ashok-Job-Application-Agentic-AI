    {
      "parameters": {
        "jsCode": "const newJobs = $('Filter Empty Results').all().map(i => i.json);\nconst existingJobs = $('Read Existing Jobs').all().map(i => i.json);\nconst existingHashes = new Set(existingJobs.map(j => j.job_url_hash).filter(Boolean));\nconst existingUrls = new Set(existingJobs.map(j => j.job_url).filter(Boolean));\n\nconst deduped = newJobs.filter(job => {\n  if (existingHashes.has(job.job_url_hash)) return false;\n  if (existingUrls.has(job.job_url)) return false;\n  return true;\n});\n\nif (deduped.length === 0) {\n  return [{ json: { _no_new_jobs: true, message: `All ${newJobs.length} jobs already exist in sheet` } }];\n}\nreturn deduped.map(j => ({ json: j }));"
      },
