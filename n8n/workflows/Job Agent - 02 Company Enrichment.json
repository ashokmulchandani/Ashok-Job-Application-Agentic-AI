    {
      "parameters": {
        "jsCode": "const job = $('Extract Full Description').item.json;\nconst companyMarkdown = $json.data?.markdown || 'No website content available';\n\nfunction clean(str) {\n  return (str || '').replace(/[\\x00-\\x1f\\x7f]/g, ' ').replace(/\\s+/g, ' ').trim();\n}\n\nconst body = {\n  messages: [\n    {\n      role: \"system\",\n      content: \"You extract concise company research for job application tailoring. Return JSON only with: company_summary (2-3 sentences), products (array), customers (array), values (array), technical_signals (array of tech/tools mentioned), hiring_signals (array), keywords (array of important terms for resume tailoring).\"\n    },\n    {\n      role: \"user\",\n      content: \"Company: \" + clean(job.company_name) + \" Job Title: \" + clean(job.title) + \" Company Website Content: \" + clean(companyMarkdown).slice(0, 4000) + \" Job Description: \" + clean(job.description).slice(0, 3000)\n    }\n  ],\n  response_format: { type: \"json_object\" },\n  max_tokens: 1000\n};\n\nreturn [{ json: { body_string: JSON.stringify(body) } }];\n"
      },
