    {
      "parameters": {
        "jsCode": "const mapResult = $json;\nconst mapLinks = mapResult.links || [];\n\n// Get company_website from upstream nodes\nlet companyWebsite = '';\ntry { companyWebsite = $('Extract Full Description').item.json.company_website || ''; } catch(e) {}\nif (!companyWebsite) {\n  try { companyWebsite = $('Extract Company URL').item.json.company_website || ''; } catch(e) {}\n}\n\nconst baseUrl = companyWebsite.replace(/\\/$/, '');\nlet sitemapUrls = [];\nlet sitemapSource = 'none';\n\n// Helper: fetch with timeout\nasync function safeFetch(url) {\n  try {\n    const resp = await fetch(url, { signal: AbortSignal.timeout(5000) });\n    if (resp.ok) return await resp.text();\n  } catch(e) {}\n  return '';\n}\n\n// Helper: extract <loc> URLs from XML\nfunction extractLocs(xml) {\n  const locs = [];\n  const re = /<loc>(https?:\\/\\/[^<]+)<\\/loc>/gi;\n  let m;\n  while ((m = re.exec(xml)) !== null) locs.push(m[1]);\n  return locs;\n}\n\n// Step 1: Try robots.txt for sitemap path\nconst robotsTxt = await safeFetch(baseUrl + '/robots.txt');\nlet customSitemapUrl = '';\nif (robotsTxt) {\n  const sm = robotsTxt.match(/Sitemap:\\s*(https?:\\/\\/[^\\s]+)/i);\n  if (sm) customSitemapUrl = sm[1].trim();\n}\n\n// Step 2: Try sitemap paths in order\nconst sitemapPaths = [\n  customSitemapUrl,\n  baseUrl + '/sitemap.xml',\n  baseUrl + '/sitemap_index.xml',\n  baseUrl + '/wp-sitemap.xml',\n  baseUrl + '/site-map.xml',\n  baseUrl + '/sitemap.json',\n].filter(Boolean);\n\n// Add path-prefix sitemaps (e.g. sgfleet.com/au -> /au/sitemap/sitemap.xml)\ntry {\n  const urlObj = new URL(baseUrl);\n  const pathParts = urlObj.pathname.split('/').filter(Boolean);\n  if (pathParts.length > 0) {\n    sitemapPaths.push(urlObj.origin + '/' + pathParts[0] + '/sitemap/sitemap.xml');\n  }\n  sitemapPaths.push(urlObj.origin + '/sitemap/sitemap.xml');\n} catch(e) {}\n\nfor (const smUrl of sitemapPaths) {\n  if (sitemapUrls.length > 5) break;\n  const content = await safeFetch(smUrl);\n  if (!content) continue;\n\n  // Check if it's actual XML with <loc> tags (not HTML disguised as 200)\n  if (content.includes('<loc>')) {\n    const locs = extractLocs(content);\n    // Filter out junk pages\n    const useful = locs.filter(u => !u.includes('/404') && !u.includes('/search-results') && !u.includes('/disclaimer'));\n    if (useful.length > 5) {\n      sitemapUrls = useful;\n      sitemapSource = smUrl;\n      break;\n    }\n  }\n\n  // Check for sitemap index (contains links to other sitemaps)\n  if (content.includes('<sitemap>')) {\n    const subSitemaps = extractLocs(content);\n    for (const sub of subSitemaps.slice(0, 3)) {\n      const subContent = await safeFetch(sub);\n      if (subContent) {\n        const subLocs = extractLocs(subContent);\n        sitemapUrls.push(...subLocs);\n      }\n    }\n    if (sitemapUrls.length > 5) {\n      sitemapSource = smUrl + ' (index)';\n      break;\n    }\n  }\n\n  // Check for JSON sitemap\n  if (smUrl.endsWith('.json') && content.startsWith('{')) {\n    try {\n      const j = JSON.parse(content);\n      const jsonUrls = (j.urls || j.pages || []).map(u => typeof u === 'string' ? u : u.url || u.loc).filter(Boolean);\n      if (jsonUrls.length > 5) {\n        sitemapUrls = jsonUrls;\n        sitemapSource = smUrl;\n        break;\n      }\n    } catch(e) {}\n  }\n}\n\n// Combine: sitemap URLs + Firecrawl /map URLs (deduped)\nconst allLinks = [...new Set([...sitemapUrls, ...mapLinks])];\n\n// Priority patterns for picking best pages\nconst priorityPatterns = [/about/i, /team/i, /product/i, /service/i, /career/i, /what-we-do/i, /our-story/i, /innovation/i, /solution/i, /fleet/i, /commitment/i, /sustainability/i, /esg/i];\n\nconst urls = [baseUrl];\n\n// First pass: priority pages\nfor (const link of allLinks) {\n  if (urls.length >= 8) break;\n  const isHome = link === baseUrl || link === baseUrl + '/';\n  const isPriority = priorityPatterns.some(p => p.test(link));\n  if (!isHome && isPriority && !urls.includes(link) && !link.endsWith('.pdf')) {\n    urls.push(link);\n  }\n}\n\n// Second pass: fill up to 5 minimum\nif (urls.length < 5) {\n  for (const link of allLinks) {\n    if (urls.length >= 5) break;\n    if (!urls.includes(link) && !link.endsWith('.pdf') && !link.includes('/404')) {\n      urls.push(link);\n    }\n  }\n}\n\nreturn [{ json: {\n  scrape_urls: urls,\n  sitemap_source: sitemapSource,\n  sitemap_urls_found: sitemapUrls.length,\n  map_urls_found: mapLinks.length,\n  total_discovered: allLinks.length\n} }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        9040,
        3856
      ],
      "id": "0478e3af-3525-412c-880c-fb7c3966d662",
      "name": "Pick Top Pages"
    },
    {
      "parameters": {
        "jsCode": "const input = $json;\nconst urls = input.scrape_urls || [];\nconst apiKey = 'fc-2357a08dfb754e50a94dfe4c1d15d2ca';\nlet combinedMarkdown = '';\n\nfor (const url of urls) {\n  try {\n    const resp = await fetch('https://api.firecrawl.dev/v1/scrape', {\n      method: 'POST',\n      headers: {\n        'Authorization': 'Bearer ' + apiKey,\n        'Content-Type': 'application/json'\n      },\n      body: JSON.stringify({ url, formats: ['markdown'], onlyMainContent: true })\n    });\n    const data = await resp.json();\n    const md = data.data?.markdown || '';\n    if (md) {\n      combinedMarkdown += '\\n\\n--- PAGE: ' + url + ' ---\\n\\n' + md.slice(0, 3000);\n    }\n  } catch (e) {}\n}\n\nreturn [{ json: {\n  ...input,\n  data: { markdown: combinedMarkdown.slice(0, 12000) }\n} }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        9232,
        3856
      ],
      "id": "27c17012-b163-403e-8b68-6e1a6d65710f",
      "name": "Scrape and Combine Pages"
    },
    {
      "parameters": {
        "jsCode": "const job = $('Prepare Job Scrape').item.json;\nconst scrapeResult = $('Firecrawl Scrape Job Page').item.json;\nconst fullDescription = scrapeResult.data?.markdown || job.description || '';\n\nconst excludedDomains = [\n  'seek.com', 'seek.com.au', 'au.seek.com',\n  'linkedin.com', 'indeed.com', 'glassdoor.com',\n  'jora.com', 'adzuna.com', 'careerone.com',\n  'ethicaljobs.com.au', 'google.com', 'googleapis.com',\n  'gstatic.com', 'facebook.com', 'twitter.com',\n  'cdn.seeklearning.com.au', 'help.au.seek.com'\n];\nconst urlRegex = /https?:\\/\\/(?:www\\.)?([a-zA-Z0-9.-]+\\.[a-z]{2,})/gi;\nlet match;\nlet companyWebsite = '';\nwhile ((match = urlRegex.exec(fullDescription)) !== null) {\n  const domain = match[1].toLowerCase();\n  const isExcluded = excludedDomains.some(ex => domain === ex || domain.endsWith('.' + ex));\n  if (!isExcluded) {\n    companyWebsite = match[0].split(/[)\\s]/)[0];\n    break;\n  }\n}\n\nreturn [{ json: {\n  ...job,\n  description: fullDescription.slice(0, 10000),\n  company_website: companyWebsite || job.company_website || '',\n  status: 'enrichment_pending'\n} }];\n"
      },
