      "id": "9e8f7a2e-1bbc-4ac3-b45c-d235df489620",
      "name": "Has Screenshot?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        -240,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "const job = $json;\nconst base64 = job.screenshot_base64;\n\n// Build filename matching naming convention\nconst now = new Date();\nconst day = String(now.getDate()).padStart(2, '0');\nconst months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];\nconst mon = months[now.getMonth()];\nconst yr = String(now.getFullYear()).slice(-2);\nconst dateStr = `${day}_${mon}_${yr}`;\nconst searchKw = (job.search_keywords || job.title || '').replace(/[^a-zA-Z0-9]/g, '_');\nconst company = (job.company_name || '').replace(/[^a-zA-Z0-9]/g, '_');\nconst title = (job.title || '').replace(/[^a-zA-Z0-9]/g, '_');\nconst location = (job.location || 'Sydney').replace(/[^a-zA-Z0-9]/g, '_');\nconst fileName = `Ashok_Mulchandani_${searchKw}_${dateStr}_JD_screenshot_${company}_${title}_${location}.png`;\n\nreturn [{\n  json: { ...job, file_name: fileName },\n  binary: {\n    data: {\n      data: base64.replace(/^data:image\\/\\w+;base64,/, ''),\n      mimeType: 'image/png',\n      fileName: fileName\n    }\n  }\n}];\n"
      },
      "id": "7a50eb62-f084-41d5-979e-a0e70bf2cc99",
