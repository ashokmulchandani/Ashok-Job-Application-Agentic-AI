      "name": "Prepare Job Scrape"
    },
    {
      "parameters": {
        "jsCode": "const job = $json;\n\n// Combine key fields into a single text for embedding\nconst parts = [\n  'Job Title: ' + (job.title || ''),\n  'Company: ' + (job.company_name || ''),\n  'Location: ' + (job.location || ''),\n  'Description: ' + (job.description || '').slice(0, 3000),\n  'Company Summary: ' + (job.company_summary || ''),\n];\n\n// Parse company_research if it's a string\nlet research = job.company_research || '';\nif (typeof research === 'string' && research.startsWith('{')) {\n  try {\n    const parsed = JSON.parse(research);\n    parts.push('Products: ' + (parsed.products || []).join(', '));\n    parts.push('Values: ' + (parsed.values || []).join(', '));\n    parts.push('Technical Signals: ' + (parsed.technical_signals || []).join(', '));\n    parts.push('Keywords: ' + (parsed.keywords || []).join(', '));\n  } catch(e) {}\n}\n\nconst content = parts.filter(Boolean).join('\\n');\n\n// Detect industry from description/research\nconst text = content.toLowerCase();\nlet industry = 'General';\nif (text.includes('retail') || text.includes('e-commerce') || text.includes('shopping')) industry = 'Retail';\nelse if (text.includes('defence') || text.includes('navy') || text.includes('military')) industry = 'Defence';\nelse if (text.includes('health') || text.includes('medical') || text.includes('hospital')) industry = 'Healthcare';\nelse if (text.includes('manufacturing') || text.includes('factory')) industry = 'Manufacturing';\nelse if (text.includes('finance') || text.includes('banking') || text.includes('insurance')) industry = 'Finance';\nelse if (text.includes('government') || text.includes('council') || text.includes('procurement')) industry = 'Government';\nelse if (text.includes('logistics') || text.includes('supply chain') || text.includes('transport')) industry = 'Supply Chain';\n\nconst metadata = {\n  search_keywords: job.search_keywords || '',\n  job_url: job.job_url || '',\n  company_website: job.company_website || '',\n  contract_type: job.contract_type || '',\n  remote_policy: job.remote_policy || '',\n  enriched_at: job.updated_at || new Date().toISOString()\n};\n\nreturn [{ json: {\n  job_id: job.job_id,\n  title: job.title || '',\n  company_name: job.company_name || '',\n  location: job.location || '',\n  industry: industry,\n  status: job.status || 'enriched',\n  fit_score: null,\n  content: content.slice(0, 8000),\n  metadata: metadata\n} }];\n"
      },
