    {
      "parameters": {
        "method": "POST",
        "url": "=https://testashok1.openai.azure.com/openai/deployments/Test-Ashok-1-gpt-4o/chat/completions?api-version=2024-02-01",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You extract concise company research for job application tailoring. Return JSON only with: company_summary (2-3 sentences), products (array), customers (array), values (array), technical_signals (array of tech/tools mentioned), hiring_signals (array), keywords (array of important terms for resume tailoring).\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Company: {{$('Extract Full Description').item.json.company_name}}\\n\\nJob Title: {{$('Extract Full Description').item.json.title}}\\n\\nCompany Website Content:\\n{{$json.data?.markdown ? $json.data.markdown.slice(0, 4000) : 'No website content available'}}\\n\\nJob Description:\\n{{$('Extract Full Description').item.json.description.slice(0, 3000)}}\"\n    }\n  ],\n  \"response_format\": { \"type\": \"json_object\" },\n  \"max_tokens\": 1000\n}",
        "options": {}
      },
