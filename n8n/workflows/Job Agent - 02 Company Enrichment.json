    {
      "parameters": {
        "jsCode": "const job = $('Prepare Job Scrape').item.json;\nconst scrapeResult = $('Firecrawl Scrape Job Page').item.json;\nconst fullDescription = scrapeResult.data?.markdown || job.description || '';\n\nconst urlMatch = fullDescription.match(/(?:https?:\\/\\/)?(?:www\\.)?([a-zA-Z0-9-]+\\.(?:com|com\\.au|io|co|org|net|ai))/i);\nconst companyWebsite = urlMatch ? `https://www.${urlMatch[1]}` : '';\n\n// Get screenshot base64 if available\nconst screenshotResult = $('Firecrawl Screenshot Job Page').item.json;\nconst screenshotBase64 = screenshotResult.data?.screenshot || '';\n\nreturn [{ json: {\n  ...job,\n  description: fullDescription.slice(0, 10000),\n  company_website: companyWebsite || job.company_website || '',\n  screenshot_base64: screenshotBase64,\n  status: 'enrichment_pending'\n} }];"
      },
      "id": "faa69b0d-5739-4077-b31f-bb5ddfbf1b64",
      "name": "Extract Full Description",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -480,
        80
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "leftValue": "={{$json.screenshot_base64}}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
