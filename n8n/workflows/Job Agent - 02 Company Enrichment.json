{
  "name": "Job Agent - 02 Company Enrichment",
  "nodes": [
    {
      "parameters": {},
      "id": "815895da-d989-4522-86e6-0d2e261167be",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
