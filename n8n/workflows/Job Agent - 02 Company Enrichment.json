    {
      "parameters": {
        "jsCode": "const input = $json;\nconst screenshotUrl = input.data?.screenshot || '';\n\n// Job data comes from input item (passed through Has Screenshot?)\n// We need to get job info from the item - build filename from what we have\nconst now = new Date();\nconst day = String(now.getDate()).padStart(2, '0');\nconst months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];\nconst mon = months[now.getMonth()];\nconst yr = String(now.getFullYear()).slice(-2);\nconst dateStr = `${day}_${mon}_${yr}`;\n\n// Use metadata from Firecrawl response or generic fallback\nconst pageTitle = input.data?.metadata?.title || 'job';\nconst cleanTitle = pageTitle.replace(/[^a-zA-Z0-9]/g, '_').slice(0, 60);\nconst fileName = `Ashok_Mulchandani_${dateStr}_JD_screenshot_${cleanTitle}.png`;\n\nreturn [{ json: { file_name: fileName, screenshot_url: screenshotUrl } }];"
      },
